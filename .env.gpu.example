# File .env cho GPU: chỉ để các biến NHẠY CẢM (secrets).
# Các biến không nhạy cảm (device, format, ports, defaults...) được đưa vào docker-compose*.yml để user đỡ rối/đỡ trùng.
#
# Cách dùng:
# - cp .env.gpu.example .env
# - điền GEMINI_API_KEY + CLOUDFLARE_TUNNEL_TOKEN
# - chọn 1 compose GPU (prebuilt hoặc build-from-source)

# ── Gemini API (SECRET) ───────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_1,your_gemini_api_key_2

# ── Cloudflare Tunnel (SECRET) ────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token
