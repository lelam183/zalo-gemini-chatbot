# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_1,your_gemini_api_key_2
GEMINI_MODEL=gemini-3.1-flash-lite-preview,gemini-2.5-flash-lite,gemma-3-27b-it,gemini-3-flash-preview
GEMINI_VISION_MODELS=gemini-2.5-flash,gemini-3-flash-preview,gemini-3-pro-preview,gemini-3.1-flash-lite-preview,gemini-2.5-flash-lite
GEMINI_SEARCH_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-3.1-flash-lite-preview,gemini-3-flash-preview,gemini-2.5-pro
GEMINI_AUDIO_MODEL=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3.1-flash-lite-preview,gemini-3-flash-preview,gemini-2.5-pro

# ── Bot config ────────────────────────────────────────────────────────────────
SYSTEM_PROMPT=Yui - friendly Vietnamese chat bot. Keep replies short and natural.
GEMINI_TEMPERATURE=1.1

# ── Video/ASR (GPU) ───────────────────────────────────────────────────────────
VIDEO_AI_ENABLED=true
VIDEO_AI_PROVIDER=gemini
GEMINI_VIDEO_MODELS=gemini-2.5-flash-lite,gemini-3.1-flash-lite-preview,gemini-2.5-flash,gemini-3-flash-preview
GEMINI_VIDEO_MODEL=
GEMINI_VIDEO_TIMEOUT_MS=90000
GEMINI_VIDEO_POLL_MS=2500
GEMINI_VIDEO_POLL_TIMEOUT_MS=120000
YOUTUBE_VIDEO_AI_ENABLED=true
VIDEO_ASR_MAX_SECONDS=120
VIDEO_FORCE_CPU=false
VIDEO_LOCAL_FILES_ONLY=false
LOCAL_ASR_MODEL=large-v3-turbo
LOCAL_ASR_LANG=auto
VIDEO_ASR_ALLOWED_LANGS=vi,en,ja
LOCAL_ASR_FALLBACK_LANG=vi
LOCAL_ASR_BEAM_SIZE=5
LOCAL_ASR_OOM_FALLBACK_CPU=true
LOCAL_ASR_CPU_COMPUTE=int8
LOCAL_ASR_DEVICE=cuda
LOCAL_ASR_COMPUTE=float16

ENABLE_SEARCH=false
CAUTION_USERS=
GROUP_PREFIX="@yui "
BOT_MENTION_ALIASES=yui,commit,bot,ai
MEMBER_ALIASES=
BOT_OWNER_NAME=Your Name
BOT_OWNER_UID=

# ── Voice ─────────────────────────────────────────────────────────────────────
VOICE_ENABLED=false
VOICE_ONLY_MODE=false
TRANSCRIPT=false
TRANSCRIPT_DELAY_MS=1000
VOICE_SEND_METHOD=voice_url_first
VOICE_OUTPUT_EXT=m4a
VOICE_NATIVE_EMULATION=true
VOICE_NATIVE_TTL_MS=60000
VIENEU_MAX_STRETCH_RATIO=2.6
VOICE_PORT=3001
VOICE_HOST_URL=

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

VOICE_NAME=vi-VN-HoaiMyNeural
VOICE_PITCH=2
VOICE_TIMEOUT_S=300

# ── VieNeu TTS (GPU) ──────────────────────────────────────────────────────────
USE_VIENEU_TTS=true
VIENEU_GPU_ENABLED=true
VIENEU_MODE=turbo
VIENEU_MODELS=pnnbao-ump/VieNeu-TTS-v2-Turbo
VIENEU_MODEL=pnnbao-ump/VieNeu-TTS-v2-Turbo
VIENEU_API_BASE=
VIENEU_REF_AUDIO=

# ── Google TTS (optional) ─────────────────────────────────────────────────────
GOOGLE_TTS_KEY_PATH=/app/data/gcloud-tts-key.json
GOOGLE_TTS_VOICE=vi-VN-Neural2-A

# ── Paths ─────────────────────────────────────────────────────────────────────
SESSION_FILE=./data/session.json
HISTORY_DIR=./data/history
VOICE_TMP_DIR=/app/data/voice_tmp
TZ=Asia/Ho_Chi_Minh
ACTIVE_CONV_TTL_MS=120000

# ── NVIDIA runtime (GPU mode) ────────────────────────────────────────────────
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=all
ASR_CUDA_VISIBLE_DEVICES=
VOICE_CUDA_VISIBLE_DEVICES=
VIDEO_CUDA_VISIBLE_DEVICES=

VOICE_FILE_TTL_HOURS=720
